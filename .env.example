PORT=5000
NODE_ENV=development

# Supabase — backend uses the SERVICE ROLE key (never expose to browser)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# CORS — your frontend origin (use http://localhost:5173 for local dev)
FRONTEND_URL=http://localhost:5173

# Web Push (VAPID) — generate once with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=mailto:contact@zerowastefood.app

# Default radius (km) used for proximity matching when not specified
DEFAULT_RADIUS_KM=10
